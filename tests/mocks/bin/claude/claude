#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const execSync = require('child_process').execSync;

const SCRIPT_DIR = __dirname;
let mocksDir = null;
if (fs.existsSync('/tmp/arondo-mocks-dir.txt')) {
  mocksDir = fs.readFileSync('/tmp/arondo-mocks-dir.txt', 'utf8').trim();
}
const CLAUDE_STATUS_PATH = mocksDir
  ? path.join(mocksDir, 'arondo-claude-status.txt')
  : path.resolve(SCRIPT_DIR, '../../tmux/claude/arondo-claude-status.txt');
const CLAUDE_USAGE_PATH = mocksDir
  ? path.join(mocksDir, 'arondo-claude-usage.txt')
  : path.resolve(SCRIPT_DIR, '../../tmux/claude/arondo-claude-usage.txt');

const args = process.argv.slice(2);
let sessionId = null;
let prompt = null;
let resumeMode = false;

for (let i = 0; i < args.length; i++) {
  if (args[i] === '--session-id') {
    sessionId = args[i + 1];
    i++;
  } else if (args[i] === '--resume') {
    sessionId = args[i + 1];
    resumeMode = true;
    i++;
  } else if (args[i] === '--print') {
    prompt = args[i + 1];
    i++;
  }
}

if (sessionId !== null || prompt !== null) {
  // Session / resume mode
  const claudeDirLog = process.env.CLAUDE_DIR_LOG;
  if (!claudeDirLog) {
    console.error("Error: CLAUDE_DIR_LOG environment variable is not set");
    process.exit(1);
  }

  if (!sessionId) {
    console.error("Error: SESSION_ID is not set");
    process.exit(1);
  }

  fs.mkdirSync(claudeDirLog, { recursive: true });

  const lines = prompt ? prompt.trim().split('\n') : [];
  const isLastLineWhatDoISaid = lines.length > 0 && lines[lines.length - 1].trim() === 'what do I said before?';

  const histFile = path.join(claudeDirLog, `${sessionId}.log`);
  if (prompt && prompt.includes('[Previous conversation context from')) {
    fs.appendFileSync(histFile, prompt + '\n');
  }

  if (!isLastLineWhatDoISaid) {
    if (prompt !== null && !prompt.includes('[Previous conversation context from')) {
      fs.appendFileSync(histFile, prompt + '\n');
    }
  }

  if (isLastLineWhatDoISaid) {
    if (!resumeMode) {
      console.log("No context, I don't know");
    } else {
      if (fs.existsSync(histFile)) {
        process.stdout.write(fs.readFileSync(histFile));
      } else {
        console.log("Context not found, I don't know");
      }
    }
  } else {
    console.log(`Mock claude received: ${prompt}`);
  }
  process.exit(0);
} else {
  // Interactive mode (e.g. running 'claude')
  if (process.env.TMUX) {
    try {
      execSync('tmux clear-history 2>/dev/null');
    } catch (e) {}
  }

  let statusContent = '';
  let usageContent = '';
  try {
    statusContent = fs.readFileSync(CLAUDE_STATUS_PATH, 'utf8');
    usageContent = fs.readFileSync(CLAUDE_USAGE_PATH, 'utf8');
  } catch (e) {
    console.error(`Error reading mock files: ${e}`);
    process.exit(1);
  }

  const targetDate = new Date(Date.now() + 2 * 24 * 60 * 60 * 1000);
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  const monthStr = months[targetDate.getMonth()];
  const day = targetDate.getDate();
  const dateStr = `${monthStr} ${day}, 4:59am (Europe/London)`;

  statusContent = statusContent.replace(/__datetime__/g, dateStr);
  usageContent = usageContent.replace(/__datetime__/g, dateStr);

  const statusLines = statusContent.split('\n');
  const initialScreen = statusLines.slice(0, 6).join('\n') + '\n';

  process.stdout.write(initialScreen);

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
  }
  process.stdin.setEncoding('utf8');

  let buffer = '';
  process.stdin.on('data', (key) => {
    for (let i = 0; i < key.length; i++) {
      const char = key[i];
      const code = char.charCodeAt(0);
      if (code === 27) { // ESC key
        buffer = '';
        if (process.env.TMUX) {
          try {
            execSync('tmux clear-history 2>/dev/null');
          } catch (e) {}
        }
        process.stdout.write('\033[H\033[2J');
        const dismissedView = statusLines.slice(0, 6).join('\n') + '\n❯ /status\n  ⎿  Settings dialog dismissed\n\n';
        process.stdout.write(dismissedView);
      } else if (char === '\r' || char === '\n') {
        const cmd = buffer.trim();
        buffer = '';
        if (cmd === '/status') {
          if (process.env.TMUX) {
            try {
              execSync('tmux clear-history 2>/dev/null');
            } catch (e) {}
          }
          process.stdout.write('\033[H\033[2J');
          process.stdout.write(statusContent);
        } else if (cmd === '/usage') {
          if (process.env.TMUX) {
            try {
              execSync('tmux clear-history 2>/dev/null');
            } catch (e) {}
          }
          process.stdout.write('\033[H\033[2J');
          process.stdout.write(usageContent);
        }
      } else if (code === 3 || code === 4) { // Ctrl+C or Ctrl+D
        process.exit(0);
      } else {
        buffer += char;
      }
    }
  });
}
