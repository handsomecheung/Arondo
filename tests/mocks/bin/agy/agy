#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const execSync = require('child_process').execSync;

const SCRIPT_DIR = __dirname;
let mocksDir = null;
if (fs.existsSync('/tmp/arondo-mocks-dir.txt')) {
  mocksDir = fs.readFileSync('/tmp/arondo-mocks-dir.txt', 'utf8').trim();
}
const AGY_USAGE_PATH = mocksDir
  ? path.join(mocksDir, 'arondo-agy-usage.txt')
  : path.resolve(SCRIPT_DIR, '../../tmux/agy/arondo-agy-usage.txt');
const TEMPLATE_FILE = path.resolve(SCRIPT_DIR, 'cli-__ts__.log');

const args = process.argv.slice(2);
let conversationId = null;
let prompt = null;
let resumeMode = false;

for (let i = 0; i < args.length; i++) {
  if (args[i] === '--conversation') {
    conversationId = args[i + 1];
    resumeMode = true;
    i++;
  } else if (args[i] === '--prompt') {
    prompt = args[i + 1];
    i++;
  }
}

if (conversationId !== null || prompt !== null) {
  // Session / resume mode
  const agyDirLog = process.env.AGY_DIR_LOG;
  if (!agyDirLog) {
    console.error("Error: AGY_DIR_LOG environment variable is not set");
    process.exit(1);
  }

  fs.mkdirSync(agyDirLog, { recursive: true });

  if (!conversationId) {
    conversationId = crypto.randomUUID();
  }

  const now = new Date();
  const timestamp = now.getFullYear() +
    String(now.getMonth() + 1).padStart(2, '0') +
    String(now.getDate()).padStart(2, '0') + '_' +
    String(now.getHours()).padStart(2, '0') +
    String(now.getMinutes()).padStart(2, '0') +
    String(now.getSeconds()).padStart(2, '0');
  const pid = process.pid;
  const logFile = path.join(agyDirLog, `cli-${timestamp}.log`);

  if (!fs.existsSync(TEMPLATE_FILE)) {
    console.error(`Error: TEMPLATE_FILE (${TEMPLATE_FILE}) not found`);
    process.exit(1);
  }

  let templateContent = fs.readFileSync(TEMPLATE_FILE, 'utf8');
  templateContent = templateContent.replace(/__pid__/g, String(pid)).replace(/__conversation_id__/g, conversationId);
  fs.writeFileSync(logFile, templateContent);

  const lines = prompt ? prompt.trim().split('\n') : [];
  const isLastLineWhatDoISaid = lines.length > 0 && lines[lines.length - 1].trim() === 'what do I said before?';

  const histFile = path.join(agyDirLog, `${conversationId}.log`);
  if (!isLastLineWhatDoISaid) {
    if (prompt !== null) {
      fs.writeFileSync(histFile, prompt + '\n');
    }
  }

  if (isLastLineWhatDoISaid) {
    if (!resumeMode) {
      console.log("No context, I don't know");
    } else {
      if (fs.existsSync(histFile)) {
        process.stdout.write(fs.readFileSync(histFile));
      } else {
        console.log("Context not found, I don't know");
      }
    }
  } else {
    console.log(`Mock agy received: ${prompt}`);
  }
  process.exit(0);
} else {
  // Interactive mode (e.g. running 'agy --add-dir ...')
  if (process.env.TMUX) {
    try {
      execSync('tmux clear-history 2>/dev/null');
    } catch (e) {}
  }

  let usageContent = '';
  try {
    usageContent = fs.readFileSync(AGY_USAGE_PATH, 'utf8');
  } catch (e) {
    console.error(`Error reading usage file: ${e}`);
    process.exit(1);
  }

  const usageLines = usageContent.split('\n');
  const initialScreen = usageLines.slice(0, 7).join('\n') + '\n';

  process.stdout.write(initialScreen);

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
  }
  process.stdin.setEncoding('utf8');

  let buffer = '';
  process.stdin.on('data', (key) => {
    for (let i = 0; i < key.length; i++) {
      const char = key[i];
      const code = char.charCodeAt(0);
      if (code === 27) { // ESC key
        buffer = '';
        if (process.env.TMUX) {
          try {
            execSync('tmux clear-history 2>/dev/null');
          } catch (e) {}
        }
        process.stdout.write('\033[H\033[2J');
        process.stdout.write(initialScreen);
      } else if (char === '\r' || char === '\n') {
        const cmd = buffer.trim();
        buffer = '';
        if (cmd === '/usage') {
          if (process.env.TMUX) {
            try {
              execSync('tmux clear-history 2>/dev/null');
            } catch (e) {}
          }
          process.stdout.write('\033[H\033[2J');
          process.stdout.write(usageContent);
        }
      } else if (code === 3 || code === 4) { // Ctrl+C or Ctrl+D
        process.exit(0);
      } else {
        buffer += char;
      }
    }
  });
}
