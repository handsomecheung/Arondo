#!/bin/bash
# Mock claude script for testing

SESSION_ID=""
PROMPT=""
RESUME_MODE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --session-id)
      SESSION_ID="$2"
      shift 2
      ;;
    --resume)
      SESSION_ID="$2"
      RESUME_MODE=true
      shift 2
      ;;
    --print)
      PROMPT="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$CLAUDE_DIR_LOG" ]; then
  echo "Error: CLAUDE_DIR_LOG environment variable is not set" >&2
  exit 1
fi

if [ -z "$SESSION_ID" ]; then
  echo "Error: SESSION_ID is not set" >&2
  exit 1
fi

mkdir -p "$CLAUDE_DIR_LOG"

# Save prompt
if [ "$PROMPT" != "what do I said before?" ]; then
  echo "$PROMPT" > "${CLAUDE_DIR_LOG}/${SESSION_ID}.log"
fi

# Output
if [ "$PROMPT" = "what do I said before?" ]; then
  if [ "$RESUME_MODE" = false ]; then
    echo "No context, I don't know"
  else
    HIST_FILE="${CLAUDE_DIR_LOG}/${SESSION_ID}.log"
    if [ -f "$HIST_FILE" ]; then
      cat "$HIST_FILE"
    else
      echo "Context not found, I don't know"
    fi
  fi
else
  echo "Mock claude received: $PROMPT"
fi

exit 0
